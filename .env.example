# Copiez vers `.env` et ajustez les valeurs.

# PostgreSQL — local ou Neon (Vercel : copiez « POSTGRES_PRISMA_URL » depuis Storage → .env)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
# Sur Vercel, si seul STORAGE_POSTGRES_PRISMA_URL existe, l’app l’utilise automatiquement.

# JWT admin (min. 16 caractères en production)
AUTH_SECRET="change-me-to-a-long-random-string"

# Compte administrateur (créé par `npm run db:seed` ou `npm run admin:sync`)
# Sur Vercel : mêmes valeurs dans Environment Variables, puis une fois :
#   DATABASE_URL=<POSTGRES_PRISMA_URL Neon>  npm run db:remote-setup
ADMIN_EMAIL="visionaffaire1@gmail.com"
ADMIN_PASSWORD="choisissez-un-mot-de-passe-fort"

# Optionnel — compte modérateur (même seed ; droits limités : pas d’édition des textes globaux du site)
# MODERATOR_EMAIL="moderateur@exemple.com"
# MODERATOR_PASSWORD="mot-de-passe-modérateur"

# PayPal — créez une app sur developer.paypal.com liée au compte qui reçoit les paiements
# (idéalement le compte associé à visionaffaire1@gmail.com).
# Paiements catalogue (panier) en dollars canadiens (CAD)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# sandbox | live
PAYPAL_MODE="sandbox"

# Rappel : l’email marchand n’est pas lu par le code ; les fonds vont au compte de l’app PayPal.

# Formulaire Contact — envoi par SMTP (ex. Gmail : mot de passe d’application)
# Destination des messages (défaut : aoudiafahem1@gmail.com si variable absente)
CONTACT_TO_EMAIL="aoudiafahem1@gmail.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="votre-compte@gmail.com"
SMTP_PASS="mot-de-passe-application-gmail"
# Optionnel — expéditeur affiché (sinon : Cirta Gallery <SMTP_USER>)
# SMTP_FROM="Cirta Gallery <noreply@votredomaine.com>"
